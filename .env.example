# دیتابیس Prisma (SQLite برای development)
# برای production (Vercel) از PostgreSQL استفاده کنید
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# نمونه PostgreSQL برای Vercel (اگر از Vercel Postgres استفاده می‌کنید)
